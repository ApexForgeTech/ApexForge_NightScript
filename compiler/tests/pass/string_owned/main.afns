package test;

extern "C" fn puts(s: cstr) -> i32;

fn main() -> i32 {
    let s: String = String.from("hello");
    defer s.free();

    let first: u8 = s[0];
    let view: str = s.as_str();

    if s.len == 5 && s.cap >= 5 && first == 104 && view.len == 5 {
        puts("ok");
    }

    return 0;
}
