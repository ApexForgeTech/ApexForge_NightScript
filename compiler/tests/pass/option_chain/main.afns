package opttest;

extern "C" fn puts(s: cstr) -> i32;

fn safe_div(a: i32, b: i32) -> Option[i32] {
    if b == 0 {
        return None;
    }
    return Some(a / b);
}

fn double_div(a: i32, b: i32, c: i32) -> Option[i32] {
    let mid = safe_div(a, b)?;
    return safe_div(mid, c);
}

fn main() -> i32 {
    let ok: Option[i32] = safe_div(10, 2);
    let none: Option[i32] = safe_div(10, 0);

    let a: i32 = match ok {
        Some => 1,
        None => 0,
    };
    let b: i32 = match none {
        Some => 0,
        None => 1,
    };

    if a == 1 { puts("some ok"); }
    if b == 1 { puts("none ok"); }

    let chained: Option[i32] = double_div(100, 5, 2);
    let c: i32 = match chained {
        Some => 1,
        None => 0,
    };
    if c == 1 { puts("chain ok"); }

    let fail: Option[i32] = double_div(100, 0, 2);
    let d: i32 = match fail {
        Some => 0,
        None => 1,
    };
    if d == 1 { puts("chain_none ok"); }

    return 0;
}
