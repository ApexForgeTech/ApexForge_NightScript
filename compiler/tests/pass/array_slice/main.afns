package test;

extern "C" fn puts(s: cstr) -> i32;

fn main() -> i32 {
    let bytes: [4]u8;
    bytes[0] = 1;
    bytes[1] = 2;
    bytes[2] = 3;
    bytes[3] = 4;
    let part: []u8 = bytes[1..3];
    let tail: []u8 = part[1..];

    if part.len == 2 && part[0] == 2 && part[1] == 3 &&
       tail.len == 1 && tail[0] == 3 {
        puts("ok");
    }

    return 0;
}
